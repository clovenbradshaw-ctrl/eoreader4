{
  "name": "eoreader4",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Holonic document-chat over an append-only event log",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "write": "node scripts/write-demo.mjs",
    "belief": "node scripts/belief-demo.mjs",
    "bench": "node scripts/surf-bench.mjs",
    "predict": "node scripts/predict-moves.mjs",
    "helix-predict": "node scripts/helix-predict.mjs",
    "dna": "node scripts/dna-code.mjs",
    "video-predict": "node scripts/video-predict.mjs",
    "horizon": "node scripts/horizon-demo.mjs",
    "credence": "node scripts/credence-measure.mjs",
    "learn:grammar": "node scripts/learn-grammar.mjs",
    "build:centroids": "node scripts/build-centroids.mjs",
    "preparse": "node scripts/preparse-corpus.mjs",
    "serve": "python3 -m http.server 8000",
    "grow-basis": "node scripts/grow-basis-demo.mjs",
    "text-generate": "node scripts/text-generate.mjs",
    "layered-generate": "node scripts/layered-generate.mjs",
    "layered-stack": "node scripts/layered-stack-demo.mjs",
    "structural-significance": "node scripts/structural-significance.mjs",
    "grained": "node scripts/predict-grained.mjs",
    "segment": "node scripts/predict-segment.mjs",
    "task-creator": "node scripts/task-creator-e2e.mjs",
    "mechanics": "node eoreader4-eval/mechanics/run.mjs ABCD",
    "essay-backwards": "node eoreader4-eval/essay-backwards.mjs",
    "essay-real-model": "node eoreader4-eval/essay-real-model.mjs",
    "essay-real-model:mock": "node eoreader4-eval/essay-real-model.mjs --mock"
  },
  "engines": {
    "node": ">=20"
  },
  "//devDependencies": "Dev-only tooling. The offline preparse (scripts/preparse-corpus.mjs) needs hyparquet; the Mechanics Test Battery (eoreader4-eval/mechanics/) needs @huggingface/transformers to run the CPU talker + MiniLM organ in Node. The browser build loads everything from a CDN — the app itself has no runtime dependencies.",
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "hyparquet": "^1.26.1",
    "hyparquet-compressors": "^1.1.1"
  },
  "license": "MIT"
}
